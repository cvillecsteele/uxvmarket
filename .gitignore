fe/site/src/content/sitrep/
fe/site/src/content/capability/
fe/site/src/content/program/
fe/site/src/data/

# -----------------------------------------------------------------------------
# Canonical vendor corpus
# -----------------------------------------------------------------------------
# `vendors/<slug>/{profile,products,canonicalize_report,migration_report}.json`
# (a few MB total across the cohort) IS tracked — that's the data the FE
# generator reads, and tracking it makes CI builds reproducible without an
# S3 dependency. The heavy mirrored evidence under `website/` (raw HTML,
# Browserless JSON, markdown, normalized text, documents — multiple GB)
# is NOT tracked; archive it to S3 separately. See
# `scripts/archive_vendors_to_s3.py` and README.md "Archive Vendors To S3".
vendors/*/website/

# -----------------------------------------------------------------------------
# Generic logs
# -----------------------------------------------------------------------------
*.log
