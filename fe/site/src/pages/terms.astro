---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';

const allVendors = await getCollection('vendor');
const totalFirms = allVendors.length;

const allReviewedIsos = allVendors.map(v => v.data.reviewed_at).sort();
const latestReviewed = allReviewedIsos[allReviewedIsos.length - 1];

function shortDate(iso: string): string {
  const d = new Date(iso + 'T00:00:00Z');
  if (Number.isNaN(d.getTime())) return iso;
  const day = String(d.getUTCDate()).padStart(2, '0');
  const month = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'][d.getUTCMonth()];
  return `${day} ${month}`;
}

const reviewedDisplay = latestReviewed ? shortDate(latestReviewed) + ' 2026' : '';
---

<BaseLayout
  title="Terms of Service · UxV Market"
  description="Terms governing use of the UxV Market reference site."
>
  <div class="page">
    <Masthead firmCount={totalFirms} reviewedAt={reviewedDisplay} />

    <article class="static-page">
      <h2>Terms of Service</h2>
      <p class="effective">Effective 25 April 2026.</p>

      <p>By accessing UxV Market (uxvmarket.com), you agree to these terms. If you do not agree, please do not use the site.</p>

      <h3>What we provide</h3>
      <p>UxV Market is an informational reference compiled from public sources. Information is provided on an "as-is" basis without warranties of any kind, express or implied, including accuracy, completeness, fitness for a particular purpose, or non-infringement.</p>

      <h3>Not advice</h3>
      <p>Nothing on this site is investment advice, procurement advice, legal advice, or export-control guidance. Decisions you make based on what you read here are yours alone. For regulated determinations (NDAA Section 848 compliance, ITAR/EAR jurisdiction, Blue UAS status), consult the official authority of record.</p>

      <h3>Permitted use</h3>
      <p>You may read, link to, cite, and quote reasonable excerpts of our content with attribution. Journalists, analysts, and researchers are explicitly welcome.</p>

      <h3>Not permitted</h3>
      <ul>
        <li>Bulk scraping, automated harvesting, or wholesale republication of the catalog.</li>
        <li>Using the data to compile a competing reference product without a separate written license.</li>
        <li>Misrepresenting our content as your own primary research.</li>
      </ul>

      <h3>Vendor names and trademarks</h3>
      <p>Company names, product names, and logos referenced on this site are the property of their respective owners. Inclusion of a vendor in this reference does not imply endorsement by that vendor or vice versa.</p>

      <h3>Corrections and takedowns</h3>
      <p>If a fact about your firm is wrong, dated, or omitted, write to <a href="mailto:corrections@uxvmarket.com">corrections@uxvmarket.com</a> with a citation. We act on sourced corrections promptly.</p>

      <h3>Changes</h3>
      <p>We may update these terms. Material changes will be noted with a revised effective date.</p>

      <h3>Contact</h3>
      <p>Questions: <a href="mailto:hello@uxvmarket.com">hello@uxvmarket.com</a>.</p>
    </article>

    <Footer firmCount={totalFirms} />
  </div>
</BaseLayout>

<style is:global>
  .page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 32px 72px 80px;
  }
  @media (max-width: 720px) {
    .page { padding: 22px 28px 60px; }
  }

  .static-page {
    max-width: 72ch;
  }
  .static-page h2 {
    font-family: var(--font-sans);
    font-size: 28px;
    font-weight: 500;
    color: var(--text);
    letter-spacing: -0.015em;
    margin-bottom: 24px;
  }
  .static-page h3 {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 32px;
    margin-bottom: 10px;
  }
  .static-page p {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--text);
    line-height: 1.6;
    margin-bottom: 14px;
  }
  .static-page a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .static-page ul {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--text);
    line-height: 1.6;
    margin: 8px 0 14px 20px;
  }
  .static-page li { margin-bottom: 6px; }
  .static-page strong { font-weight: 500; color: var(--text); }
  .static-page .effective {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--secondary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 24px;
  }
</style>
